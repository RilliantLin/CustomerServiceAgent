# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/customer_service_agent

# Auth
# In production, /api/dev-login is disabled automatically; configure Manus OAuth instead.
VITE_APP_ID=CUSTOMER_SERVICE_AGENT
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im
JWT_SECRET=replace-with-a-long-random-secret
OWNER_NAME=Your Name
OWNER_OPEN_ID=your-open-id

# Local MCP server identity. Required when running `pnpm mcp`.
# Use a numeric users.id from the database. MCP_ROLE defaults to "user"; set
# "admin" only for an existing admin user.
MCP_USER_ID=1
MCP_ROLE=user

# LLM provider
# Use "manus" to keep the original Forge path, or "openai" for OpenAI Responses API.
LLM_PROVIDER=openai
# Chat runtime: "rag" keeps the direct RAG flow; "agent" uses the server-side OpenAI Agents SDK.
CHAT_MODE=rag
# Optional Agent SDK knobs. Tracing stays redacted; handoffs are kept off until multi-agent routing is explicitly enabled.
# Before CHAT_MODE=agent reaches production, run database migrations so agent_runs and agent_run_steps exist.
AGENT_TRACING_ENABLED=false
AGENT_HANDOFFS_ENABLED=false

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: override embeddings when a company proxy uses a different route/model.
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_PATH=/v1/embeddings
# Embeddings provider: use "local" for a local OpenAI-compatible embedding server,
# "voyage" for Voyage AI, or "openai" to keep OpenAI embeddings.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_BASE_URL=http://localhost:8080
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_PATH=/v1/embeddings
# Optional, only when your local embedding server requires an auth token.
LOCAL_EMBEDDING_API_KEY=
VOYAGE_API_KEY=pa-your-voyage-api-key
VOYAGE_BASE_URL=https://api.voyageai.com
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_EMBEDDING_PATH=/v1/embeddings
# Set to false when your proxy has not enabled embeddings yet; keyword RAG fallback stays active.
RAG_EMBEDDINGS_ENABLED=true

# Manus Forge fallback / legacy provider
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-manus-forge-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-key

# App
# Runtime observability logs provider/model/latency/token metadata and redacts keys, cookies, passwords, and card-like values.
VITE_APP_TITLE=客服工单系统
VITE_APP_LOGO=https://example.com/logo.png
