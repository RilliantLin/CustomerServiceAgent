# Database
DATABASE_URL=mysql://root:password@localhost:3306/customer_service_agent

# Auth
VITE_APP_ID=CUSTOMER_SERVICE_AGENT
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im
JWT_SECRET=replace-with-a-long-random-secret
OWNER_NAME=Your Name
OWNER_OPEN_ID=your-open-id

# LLM provider
# Use "manus" to keep the original Forge path, or "openai" for OpenAI Responses API.
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: override embeddings when a company proxy uses a different route/model.
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_PATH=/v1/embeddings
# Embeddings provider: use "voyage" for Voyage AI or "openai" to keep OpenAI embeddings.
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=pa-your-voyage-api-key
VOYAGE_BASE_URL=https://api.voyageai.com
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_EMBEDDING_PATH=/v1/embeddings
# Set to false when your proxy has not enabled embeddings yet; keyword RAG fallback stays active.
RAG_EMBEDDINGS_ENABLED=true

# Manus Forge fallback / legacy provider
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-manus-forge-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-key

# App
VITE_APP_TITLE=客服工单系统
VITE_APP_LOGO=https://example.com/logo.png
